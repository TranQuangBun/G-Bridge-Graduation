{
  "name": "gbridge-backend",
  "version": "1.0.0",
  "description": "G-Bridge Backend API - Platform connecting interpreters and companies",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "start:with-docs": "(npm run docs:generate || true) && npm start",
    "dev": "nodemon src/server.js",
    "dev:with-docs": "(npm run docs:generate || true) && npm run dev",
    "docs:generate": "echo 'Swagger docs are auto-generated from JSDoc comments. No script needed.'",
    "docs:dev": "npm run docs:generate && npm run dev",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "gbridge",
    "interpreter",
    "translator",
    "backend",
    "api"
  ],
  "author": "G-Bridge Team",
  "license": "ISC",
  "dependencies": {
    "@paypal/checkout-server-sdk": "^1.0.3",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-list-endpoints": "^7.1.1",
    "form-data": "^4.0.4",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.30.1",
    "multer": "^2.0.2",
    "mysql2": "^3.15.3",
    "querystring": "^0.2.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.27",
    "pdf2pic": "^3.1.1"
