# ============================================
# G-Bridge Backend Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values
# cp env.example .env

# ============================================
# Node.js Environment
# ============================================
# Options: development, production, test
NODE_ENV=development

# ============================================
# Server Configuration
# ============================================
# Port for the backend API server
PORT=4000

# Frontend URL for CORS configuration
FRONTEND_URL=http://localhost:3000

# ============================================
# Database Configuration (MySQL)
# ============================================
# Database host (use 'mysql' if running in Docker, 'localhost' for local development)
DB_HOST=localhost
# Database port
DB_PORT=3306
# Database name
DB_NAME=gbridge_db
# Database username
DB_USER=root
# Database password
DB_PASSWORD=

# ============================================
# JWT Authentication
# ============================================
# Secret key for JWT token signing (CHANGE THIS IN PRODUCTION!)
# Generate a strong random string for production
JWT_SECRET=your-super-secret-jwt-key-change-in-production
# JWT token expiration time (e.g., "7d", "24h", "1h")
JWT_EXPIRES_IN=7d

# ============================================
# Image Upload Service (ImgBB)
# ============================================
# Get your API key from: https://api.imgbb.com/
IMGBB_API_KEY=your_imgbb_api_key_here

# ============================================
# Payment Gateway - VNPay
# ============================================
# VNPay Terminal Code (Merchant ID)
VNP_TMN_CODE=YOUR_TMN_CODE
# VNPay Hash Secret
VNP_HASH_SECRET=YOUR_HASH_SECRET
# VNPay API URL (sandbox or production)
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# VNPay Return URL (where user is redirected after payment)
VNP_RETURN_URL=http://localhost:3000/payment/vnpay/callback
# VNPay IPN URL (webhook for payment notifications)
VNP_IPN_URL=http://localhost:4000/api/payments/webhook/vnpay

# ============================================
# Payment Gateway - PayPal
# ============================================
# PayPal mode: sandbox or live
PAYPAL_MODE=sandbox
# PayPal Client ID
PAYPAL_CLIENT_ID=YOUR_CLIENT_ID
# PayPal Client Secret
PAYPAL_CLIENT_SECRET=YOUR_CLIENT_SECRET
# PayPal Return URL (where user is redirected after successful payment)
PAYPAL_RETURN_URL=http://localhost:3000/payment/paypal/success
# PayPal Cancel URL (where user is redirected if payment is cancelled)
PAYPAL_CANCEL_URL=http://localhost:3000/payment/paypal/cancel
# PayPal Webhook URL (for payment notifications)
PAYPAL_WEBHOOK_URL=http://localhost:4000/api/payments/webhook/paypal

