# ============================================
# Docker Compose Override Example
# ============================================
# 
# MỤC ĐÍCH:
# File này cho phép bạn override/extend cấu hình từ docker-compose.yml
# mà không cần sửa file docker-compose.yml chính
#
# CÁCH SỬ DỤNG:
# 1. Copy file này: cp docker-compose.override.yml.example docker-compose.override.yml
# 2. Sửa các giá trị cần thiết trong docker-compose.override.yml
# 3. docker-compose.override.yml sẽ tự động được load khi chạy docker-compose
#
# LỢI ÍCH:
# - Giữ docker-compose.yml gốc không đổi (cho team)
# - Mỗi developer có thể customize riêng
# - File .override.yml thường được gitignore (chứa secrets/passwords)
#
# LƯU Ý:
# - docker-compose.override.yml tự động được merge với docker-compose.yml
# - Giá trị trong override sẽ thay thế giá trị trong file gốc
# - Có thể override bất kỳ field nào: environment, ports, volumes, etc.

version: '3.8'

services:
  mysql:
    environment:
      # Override MySQL root password (thay đổi password mặc định)
      MYSQL_ROOT_PASSWORD: your_secure_root_password
      # Override MySQL user password
      MYSQL_PASSWORD: your_secure_user_password

  backend:
    environment:
      # Override JWT secret (QUAN TRỌNG: đổi trong production)
      JWT_SECRET: your-super-secret-jwt-key-change-in-production
      # Override port nếu port 4000 đã bị chiếm
      PORT: 4000
      # Override NODE_ENV nếu cần (development/production)
      # NODE_ENV: development
      
      # VNPay Configuration (QUAN TRỌNG: Cần cấu hình để thanh toán hoạt động)
      # Đăng ký tài khoản VNPay sandbox tại: https://sandbox.vnpayment.vn/
      # Sau đó lấy credentials từ dashboard và điền vào đây:
      # VNP_TMN_CODE: your_vnpay_tmn_code
      # VNP_HASH_SECRET: your_vnpay_hash_secret
      # VNP_RETURN_URL: http://localhost:3000/payment/vnpay/callback
      # VNP_IPN_URL: http://localhost:4000/api/payments/webhook/vnpay
      
      # MoMo Configuration (QUAN TRỌNG: Cần cấu hình để thanh toán hoạt động)
      # Đăng ký tài khoản MoMo tại: https://developers.momo.vn/
      # Giá trị mặc định dưới đây là sandbox credentials (có thể dùng để test)
      # 
      # ============================================
      # CÓ CẦN NGROK KHÔNG?
      # ============================================
      # - KHÔNG BẮT BUỘC: Nếu chỉ test payment flow (redirect và verify qua callback URL)
      # - CẦN NGROK: Nếu muốn test webhook/IPN từ MoMo (MoMo gọi về server của bạn)
      #   → MoMo không thể gọi trực tiếp đến localhost, cần ngrok để expose localhost ra internet
      # - PRODUCTION: Không cần ngrok vì đã có domain thật
      #
      # CÁCH SỬ DỤNG NGROK (nếu cần test webhook):
      # 1. Cài ngrok: https://ngrok.com/download
      # 2. Chạy: ngrok http 4000
      # 3. Copy URL (ví dụ: https://abc123.ngrok-free.app)
      # 4. Set MOMO_NOTIFY_URL dưới đây với ngrok URL
      #
      # Để override, uncomment và thay đổi các giá trị sau:
      # MOMO_PARTNER_CODE: MOMOBKUN20180529
      # MOMO_ACCESS_KEY: klm05TvNBzhg7h7j
      # MOMO_SECRET_KEY: at67qH6mk8w5Y1nAyMoYKMWACiEi2bsa
      # MOMO_API_URL: https://test-payment.momo.vn/v2/gateway/api/create
      # MOMO_RETURN_URL: http://localhost:3000/payment/momo/callback
      # 
      # MOMO_NOTIFY_URL (chọn một trong hai):
      # - Không dùng webhook: http://localhost:4000/api/payments/webhook/momo (MoMo sẽ không gọi được)
      # - Dùng ngrok để test webhook: https://your-ngrok-url.ngrok-free.app/api/payments/webhook/momo
      # 
      # MOMO_ENVIRONMENT: sandbox (hoặc production)

  frontend:
    environment:
      # Override API URL nếu backend chạy trên port khác
      REACT_APP_API_URL: http://localhost:4000/api
