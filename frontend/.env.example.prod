# ============================================
# G-Bridge Frontend Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values
# cp env.example .env
#
# Note: React requires environment variables to be prefixed with REACT_APP_
# to be accessible in the browser. Variables without this prefix will be ignored.

# ============================================
# API Configuration
# ============================================
# Backend API base URL
# For local development: http://localhost:4000/api
# For production: https://api.yourdomain.com/api
# For Docker: http://localhost:4000/api (browser connects to host, not container)
REACT_APP_API_URL=http://localhost:4000/api

# ============================================
# React Development Configuration
# ============================================
# Enable file watching in Docker (set to true if running in Docker)
CHOKIDAR_USEPOLLING=true
# Enable webpack polling for file changes
WATCHPACK_POLLING=true
# Enable React Fast Refresh
FAST_REFRESH=true
# Generate source maps for debugging
GENERATE_SOURCEMAP=true

# ============================================
# Optional: Application Environment
# ============================================
# Application environment (development, staging, production)
# REACT_APP_ENV=development

# ============================================
# Optional: Feature Flags
# ============================================
# Enable/disable specific features
# REACT_APP_ENABLE_ANALYTICS=false
# REACT_APP_ENABLE_DEBUG_MODE=true

